{
  "version": 2,
  "scriptId": "gt-18-multi-tab",
  "name": "GT18 多标签页：switchTab / closeTab / page_exists",
  "description": "click 打开 target=_blank 新标签 / switchTab / check(page_exists,url_contains) / extract(url) / closeTab / 切回主标签",
  "fields": [],
  "phases": [
    {
      "kind": "phase", "name": "tabs", "type": "sequential", "aiGoal": "打开新标签页，切换、校验、提取 URL、关闭后切回主标签",
      "steps": [
        { "kind": "step", "name": "goto-multi", "action": "navigate", "url": "http://localhost:8088/multi-tab.html" },
        { "kind": "step", "name": "check-main", "action": "check", "detect": { "type": "page_contains", "keywords": ["多标签页测试页"] }, "then": "nothing" },
        { "kind": "step", "name": "open-tab", "action": "click", "selector": "#open-tab" },
        { "kind": "step", "name": "wait-tab", "action": "wait", "ms": 600 },
        { "kind": "step", "name": "switch-new", "action": "switchTab", "index": 1 },
        { "kind": "step", "name": "check-page-exists", "action": "check", "detect": { "type": "page_exists", "urlContains": "login" }, "then": "nothing" },
        { "kind": "step", "name": "check-new-url", "action": "check", "detect": { "type": "url_contains", "value": "login" }, "then": "nothing" },
        { "kind": "step", "name": "extract-tab-url", "action": "extract", "extractType": "url", "storeAs": "tabUrl" },
        { "kind": "step", "name": "close-new", "action": "closeTab", "index": 1 },
        { "kind": "step", "name": "switch-main", "action": "switchTab", "index": 0 },
        { "kind": "step", "name": "check-back-main", "action": "check", "detect": { "type": "page_contains", "keywords": ["主标签页"] }, "then": "nothing" },
        { "kind": "step", "name": "shot", "action": "screenshot", "screenshotType": "fullPage", "folder": "../tests/artifacts/shots", "filename": "gt-18" }
      ]
    }
  ]
}
