{
  "version": 2,
  "scriptId": "gt-08-dialog-presetup",
  "name": "GT08 对话框处理（preSetup + handleDialog）",
  "description": "preSetup(auto_accept/auto_dismiss) / handleDialog(延迟弹窗) / check(dialog_contains, selector_text)",
  "fields": [],
  "phases": [
    {
      "kind": "phase",
      "name": "dialogs",
      "type": "sequential",
      "aiGoal": "处理确认/警告/延迟三类原生对话框并校验结果",
      "steps": [
        { "kind": "step", "name": "goto-dialog", "action": "navigate", "url": "http://localhost:8088/dialog.html" },
        { "kind": "step", "name": "confirm-accept", "action": "click", "selector": "#btn-confirm", "preSetup": { "dialogHandler": "auto_accept" } },
        { "kind": "step", "name": "check-confirm-accept", "action": "check", "detect": { "all": [ { "type": "selector_text", "selector": "#confirm-result", "keywords": ["已确认"] }, { "type": "dialog_contains", "keywords": ["确认删除"] } ] }, "then": "nothing" },
        { "kind": "step", "name": "confirm-dismiss", "action": "click", "selector": "#btn-confirm", "preSetup": { "dialogHandler": "auto_dismiss" } },
        { "kind": "step", "name": "check-confirm-dismiss", "action": "check", "detect": { "type": "selector_text", "selector": "#confirm-result", "keywords": ["已取消"] }, "then": "nothing" },
        { "kind": "step", "name": "trigger-delayed", "action": "click", "selector": "#btn-delayed" },
        { "kind": "step", "name": "handle-delayed", "action": "handleDialog", "accept": true },
        { "kind": "step", "name": "check-delayed", "action": "check", "detect": { "all": [ { "type": "selector_text", "selector": "#delayed-done", "keywords": ["延迟已关闭"] }, { "type": "dialog_contains", "keywords": ["延迟弹窗"] } ] }, "then": "nothing" },
        { "kind": "step", "name": "alert-accept", "action": "click", "selector": "#btn-alert", "preSetup": { "dialogHandler": "auto_accept" } },
        { "kind": "step", "name": "check-alert", "action": "check", "detect": { "type": "selector_text", "selector": "#alert-done", "keywords": ["已关闭"] }, "then": "nothing" },
        { "kind": "step", "name": "shot", "action": "screenshot", "screenshotType": "fullPage", "folder": "../tests/artifacts/shots", "filename": "gt-08" }
      ]
    }
  ]
}
