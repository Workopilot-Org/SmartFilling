{
  "AiProvider": {
    "ApiKey": "",
    "ModelId": "deepseek-v3.2",
    "Endpoint": "https://dashscope.aliyuncs.com/compatible-mode/v1"
  },
  "ScriptEngine": {
    "Headless": false,
    "SlowMo": 0,
    "Viewport": { "Width": 1280, "Height": 720 },
    "BrowserPath": null,
    "DebugMode": false,
    "DefaultTimeout": 30000,
    "MaxScriptDuration": 36000000,
    "StepRetry": { "Count": 1, "Interval": 1000 },
    "OnError": "stop",
    "MaxAiTurns": 30,
    "DefaultAiTimeout": 300000,
    "WaitCheckInterval": 2000,
    "MaxLoopCount": 100,
    "MaxPhaseGotoCount": 20,
    "MaxPhaseJumpCount": 10,
    "Screenshot": {
      "OnPhaseProgress": false,
      "OnStepFailure": false,
      "OnTaskComplete": false,
      "OnTaskFailure": false,
      "CompressQuality": 70,
      "ActionDefaultFolder": "screenshots/",
      "OnStepFailureFolder": "logs/"
    },
    "Compression": {
      "Threshold": 30,
      "MinimumPreserved": 10,
      "PreserveInitialUserMessages": true
    },
    "Rerun": {
      "MaxRowRerunCount": 2,
      "MaxPhaseRerunCount": 2,
      "Interval": 1000
    },
    "UploadRootPath": ""
  },
  "CaptchaService": {
    "Url": "http://localhost:8000"
  },
  "Platform": {
    "NetApiUrl": "",
    "JavaApiUrl": "",
    "ApiKey": "",
    "DefaultTimeoutSeconds": 30,
    "ClassificationPollIntervalMs": 5000
  },
  "WorkerOptions": {
    "BaseUrl": "http://localhost:5245",
    "StartTaskTimeoutSeconds": 30
  },
  "AppOptions": {
    "RecordOutputAllFields": true,
    "RecordActionDelay": 500,
    "MaxRecordTurns": 500
  },
  "ChatSession": {
    "ExpirationMinutes": 60
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/app-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
