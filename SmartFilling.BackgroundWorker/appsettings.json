{
  "WorkerOptions": {
    "TaskMode": "HTTP",
    "MaxConcurrentTasks": 1,
    "BaseUrl": "",
    "CorsOrigins": ["*"],
    "IgnoreNullFieldsOnScriptValidation": true
  },
  "AiProvider": {
    "ApiKey": "",
    "ModelId": "deepseek-v3.2",
    "Endpoint": "https://dashscope.aliyuncs.com/compatible-mode/v1",
    "CircuitBreakerThreshold": 5
  },
  "ScriptEngine": {
    "Headless": false,
    "SlowMo": 0,
    "Viewport": {
      "Width": 1280,
      "Height": 720
    },
    "BrowserPath": null,
    "DefaultTimeout": 30000,
    "MaxScriptDuration": 600000,
    "StepRetry": {
      "Count": 1,
      "Interval": 1000
    },
    "OnError": "stop",
    "MaxAiTurns": 30,
    "DefaultAiTimeout": 180000,
    "WaitCheckInterval": 2000,
    "MaxLoopCount": 100,
    "DebugMode": false,
    "MaxPhaseGotoCount": 20,
    "MaxPhaseJumpCount": 10,
    "Screenshot": {
      "OnPhaseProgress": false,
      "OnStepFailure": false,
      "OnTaskComplete": true,
      "OnTaskFailure": true,
      "CompressQuality": 70,
      "ActionDefaultFolder": "screenshots/",
      "OnStepFailureFolder": "logs/"
    },
    "Compression": {
      "Threshold": 30,
      "MinimumPreserved": 5,
      "PreserveInitialUserMessages": true
    },
    "Rerun": {
      "MaxRowRerunCount": 2,
      "MaxPhaseRerunCount": 2,
      "Interval": 1000
    },
    "UploadRootPath": ""
  },
  "CaptchaService": {
    "Url": "http://localhost:8000"
  },
  "WsClient": {
    "ServerUrl": "",
    "ClientId": "",
    "HeartbeatIntervalSeconds": 30,
    "TaskPollIntervalSeconds": 30,
    "RequirePong": true,
    "PongTimeoutSeconds": 60,
    "MaxPongTimeouts": 3,
    "ReconnectIntervalSeconds": 10,
    "MaxDisconnectBufferMessages": 100,
    "ScreenshotOnProgress": false,
    "ScreenshotOnComplete": false
  },
  "Platform": {
    "JavaApiUrl": "",
    "AttachmentBaseUrl": "",
    "ApiKey": "",
    "DefaultTimeoutSeconds": 30
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/worker-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
